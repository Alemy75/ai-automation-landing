---
// src/components/CtaFinal.astro
---
<section class="cta-final" id="contact">
  <div class="wrap">
    <h2>Поехали<br/><em>запускать?</em></h2>
    <div class="cta-final-grid">
      <div class="cta-final-left">
        <p class="cta-final-lede">30 минут разговора &mdash;&nbsp;и&nbsp;вы&nbsp;получите план автоматизации со&nbsp;сроками и&nbsp;сметой. Бесплатно.</p>
        <div class="contact-alt">
          <a class="contact-alt-item" href="https://t.me/boost_by_ai" target="_blank" rel="noopener noreferrer">
            <span class="contact-alt-label">Telegram</span>
            <span class="contact-alt-val">@boost_by_ai &rarr;</span>
          </a>
          <a class="contact-alt-item" href="tel:+79222645956">
            <span class="contact-alt-label">Телефон</span>
            <span class="contact-alt-val">+7 (922) 264-59-56</span>
          </a>
          <a class="contact-alt-item" href="mailto:is.alemy@yandex.ru">
            <span class="contact-alt-label">Email</span>
            <span class="contact-alt-val">is.alemy@yandex.ru</span>
          </a>
        </div>
      </div>

      <form class="contact-form" id="contact-form" novalidate>
        <div class="form-row">
          <label class="field">
            <span class="field-label">01 / Имя</span>
            <input type="text" name="name" placeholder="Как к&nbsp;вам обращаться?" required>
          </label>
          <label class="field">
            <span class="field-label">02 / Связь</span>
            <input type="text" name="contact" placeholder="Email, Telegram или телефон" required>
          </label>
        </div>
        <label class="field">
          <span class="field-label">03 / Ниша / бизнес</span>
          <input type="text" name="business" placeholder="Салон, ресторан, сервис…">
        </label>
        <label class="field">
          <span class="field-label">04 / Задача</span>
          <textarea name="task" rows="3" placeholder="Что хотите автоматизировать? Можно коротко." required></textarea>
        </label>

        <div class="form-submit-row">
          <label class="agree">
            <input type="checkbox" id="agree-check" required>
            <span>Согласен на&nbsp;<a href="#">обработку персональных данных</a></span>
          </label>
          <button type="submit" class="btn btn-primary form-submit">Отправить заявку <span class="arrow">→</span></button>
        </div>

        <div class="form-success" hidden>
          <div class="form-success-title">Спасибо! Заявка отправлена.</div>
          <div class="form-success-desc">Ответим в течение 2х часов в рабочее время.</div>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  import emailjs from '@emailjs/browser';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const btn = form.querySelector('.form-submit') as HTMLButtonElement;
      const success = form.querySelector('.form-success') as HTMLElement;
      const agree = document.getElementById('agree-check') as HTMLInputElement;

      const name    = (form.elements.namedItem('name')     as HTMLInputElement).value.trim();
      const contact = (form.elements.namedItem('contact')  as HTMLInputElement).value.trim();
      const business= (form.elements.namedItem('business') as HTMLInputElement).value.trim();
      const task    = (form.elements.namedItem('task')     as HTMLTextAreaElement).value.trim();

      if (!name || !contact || !task || !agree.checked) return;

      const originalText = btn.innerHTML;
      btn.innerHTML = 'Отправка…';
      btn.disabled = true;

      try {
        await emailjs.send(
          import.meta.env.PUBLIC_EMAILJS_SERVICE_ID,
          import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID,
          { from_name: name, contact, business, message: task },
          { publicKey: import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY }
        );
        form.querySelectorAll<HTMLElement>('.form-row, .field, .form-submit-row').forEach(el => el.style.display = 'none');
        success.hidden = false;
      } catch (err) {
        console.error('[EmailJS]', err);
        btn.innerHTML = 'Ошибка. Пишите в Telegram';
        btn.disabled = false;
        setTimeout(() => { btn.innerHTML = originalText; }, 3000);
      }
    });
  }
</script>
