---
// src/components/Compare.astro
---
<section class="section" id="compare">
  <div class="wrap">
    <div class="section-head reveal" data-reveal>
      <div class="section-eyebrow"><span class="num">05</span><span>СРАВНЕНИЕ</span></div>
      <h2 class="section-title">AI&nbsp;BOOST<br/>vs&nbsp;<em>остальные</em></h2>
    </div>

    <div class="compare-scroll">
    <div class="compare reveal" data-reveal>
      <div class="compare-row header">
        <div>Параметр</div>
        <div class="col-us">AI BOOST</div>
        <div>Типовое агентство</div>
      </div>
      <div class="compare-row">
        <div class="col-feature">Срок запуска</div>
        <div class="col-us"><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 12l5 5L20 6"/></svg>2–3 недели</div>
        <div class="col-them">2–3 месяца</div>
      </div>
      <div class="compare-row">
        <div class="col-feature">Понимание живой речи</div>
        <div class="col-us"><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 12l5 5L20 6"/></svg>LLM, контекст до&nbsp;20 реплик</div>
        <div class="col-them">Дерево скриптов «если-то»</div>
      </div>
      <div class="compare-row">
        <div class="col-feature">Цена за&nbsp;MVP</div>
        <div class="col-us"><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 12l5 5L20 6"/></svg>от 49 000 ₽</div>
        <div class="col-them">от 250 000 ₽</div>
      </div>
      <div class="compare-row">
        <div class="col-feature">Передача кода и&nbsp;доступов</div>
        <div class="col-us"><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 12l5 5L20 6"/></svg>Всё у&nbsp;вас</div>
        <div class="col-them"><svg class="cross" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M18 6L6 18"/></svg>Привязка к&nbsp;подрядчику</div>
      </div>
      <div class="compare-row">
        <div class="col-feature">Поддержка</div>
        <div class="col-us"><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 12l5 5L20 6"/></svg>24/7, без&nbsp;тикетов</div>
        <div class="col-them">В рабочее время</div>
      </div>
      <div class="compare-row">
        <div class="col-feature">Гарантия результата</div>
        <div class="col-us"><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 12l5 5L20 6"/></svg>В&nbsp;договоре</div>
        <div class="col-them"><svg class="cross" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M18 6L6 18"/></svg>«Постараемся»</div>
      </div>
    </div>
    </div>
  </div>
</section>
