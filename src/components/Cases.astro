---
// src/components/Cases.astro
---
<section class="section" id="cases">
  <div class="wrap">
    <div class="section-head reveal" data-reveal>
      <div class="section-eyebrow"><span class="num">03</span><span>СЦЕНАРИИ</span></div>
      <h2 class="section-title">Типовые<br/><em>задачи</em></h2>
    </div>
    <div class="cases reveal-stagger" data-reveal>
      <div class="case">
        <span class="case-tag">BEAUTY</span>
        <div class="case-meta"><span>Салон красоты / spa</span><span>Типовой сценарий*</span></div>
        <h3 class="case-title">AI-бот берёт на&nbsp;себя входящие запросы и&nbsp;запись вместо администратора</h3>
        <div class="case-kpis">
          <div><div class="case-kpi-num lime">−60–75%</div><div class="case-kpi-label">Нагрузки</div></div>
          <div><div class="case-kpi-num">+30–40%</div><div class="case-kpi-label">Записей</div></div>
          <div><div class="case-kpi-num">10–14 дн.</div><div class="case-kpi-label">Запуск</div></div>
        </div>
      </div>
      <div class="case">
        <span class="case-tag">RETAIL</span>
        <div class="case-meta"><span>Шоу-рум / магазин</span><span>Типовой сценарий*</span></div>
        <h3 class="case-title">Голосовой ассистент принимает входящие звонки и&nbsp;отвечает на&nbsp;типовые вопросы</h3>
        <div class="case-kpis">
          <div><div class="case-kpi-num lime">0</div><div class="case-kpi-label">Пропущ. звонков</div></div>
          <div><div class="case-kpi-num">+20–30%</div><div class="case-kpi-label">Конверсия</div></div>
          <div><div class="case-kpi-num">7–12 дн.</div><div class="case-kpi-label">Запуск</div></div>
        </div>
      </div>
      <div class="case">
        <span class="case-tag">SERVICE</span>
        <div class="case-meta"><span>Авто- / бытовой сервис</span><span>Типовой сценарий*</span></div>
        <h3 class="case-title">Онлайн-запись через Telegram и&nbsp;авто-напоминания сокращают неявку клиентов</h3>
        <div class="case-kpis">
          <div><div class="case-kpi-num lime">−40–60%</div><div class="case-kpi-label">Неявка</div></div>
          <div><div class="case-kpi-num">2–3×</div><div class="case-kpi-label">Онлайн-запись</div></div>
          <div><div class="case-kpi-num">10–14 дн.</div><div class="case-kpi-label">Запуск</div></div>
        </div>
      </div>
      <div class="case">
        <span class="case-tag">FOOD</span>
        <div class="case-meta"><span>Ресторан / кафе</span><span>Типовой сценарий*</span></div>
        <h3 class="case-title">AI-бот принимает брони столов и&nbsp;заказы навынос без участия персонала</h3>
        <div class="case-kpis">
          <div><div class="case-kpi-num lime">+35–45%</div><div class="case-kpi-label">Броней</div></div>
          <div><div class="case-kpi-num">−50–65%</div><div class="case-kpi-label">Рутины</div></div>
          <div><div class="case-kpi-num">12–16 дн.</div><div class="case-kpi-label">Запуск</div></div>
        </div>
      </div>
    </div>
    <p class="cases-disclaimer">* Показатели — расчётные диапазоны на&nbsp;основе отраслевой статистики и&nbsp;технических возможностей решений. Результат для конкретного проекта согласовывается индивидуально.</p>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.case').forEach(card => {
    card.addEventListener('pointermove', e => {
      const r = card.getBoundingClientRect();
      const mx = ((e.clientX - r.left) / r.width) * 100;
      const my = ((e.clientY - r.top) / r.height) * 100;
      card.style.setProperty('--mx', mx + '%');
      card.style.setProperty('--my', my + '%');
      card.style.transform = 'translateY(-4px)';
    });
    card.addEventListener('pointerleave', () => {
      card.style.transform = '';
      card.style.removeProperty('--mx');
      card.style.removeProperty('--my');
    });
  });
</script>
