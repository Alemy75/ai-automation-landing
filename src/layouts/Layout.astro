---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'AI Boost — AI-автоматизация для бизнеса',
  description = 'Строим AI-ботов, голосовых ассистентов и автоматизации для салонов, шоу-румов и локальных сервисов. Меньше рутины, больше клиентов — запуск за 2–3 недели.',
  ogImage = '/og-image.jpg',
} = Astro.props;

const canonicalUrl = Astro.url.href;
const siteUrl = (import.meta.env.SITE ?? 'https://yourdomain.ru').replace(/\/$/, '');
const siteBase = siteUrl + import.meta.env.BASE_URL.replace(/\/$/, '');

const orgSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "AI Boost",
  "url": siteBase,
  "description": description,
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "availableLanguage": "Russian"
  }
});

const webSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "AI Boost",
  "url": siteBase
});
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#F5F2EC" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteBase}${ogImage}`} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="AI Boost" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteBase}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={orgSchema} />
    <script type="application/ld+json" set:html={webSchema} />
  </head>
  <body>
    <slot />
    <div class="spotlight" aria-hidden="true"></div>

    <script>
      // Cursor spotlight
      const sp = document.querySelector('.spotlight') as HTMLElement;
      window.addEventListener('pointermove', e => {
        sp.style.setProperty('--cx', e.clientX + 'px');
        sp.style.setProperty('--cy', e.clientY + 'px');
      });

      // Magnetic buttons
      document.querySelectorAll<HTMLElement>('.btn, .nav-cta').forEach(btn => {
        btn.addEventListener('pointermove', e => {
          const r = btn.getBoundingClientRect();
          const x = (e as PointerEvent).clientX - r.left - r.width / 2;
          const y = (e as PointerEvent).clientY - r.top - r.height / 2;
          btn.style.transform = `translate(${x * 0.2}px, ${y * 0.25}px)`;
        });
        btn.addEventListener('pointerleave', () => { btn.style.transform = ''; });
      });

      // Scroll reveal + counters
      function runCounter(el: HTMLElement) {
        const to = parseInt(el.dataset.to!, 10);
        const t0 = performance.now();
        function tick(t: number) {
          const p = Math.min(1, (t - t0) / 1400);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = String(Math.round(to * eased));
          if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }

      const io = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
            e.target.querySelectorAll<HTMLElement>('.counter').forEach(runCounter);
          }
        });
      }, { threshold: 0.15 });
      document.querySelectorAll('[data-reveal]').forEach(el => io.observe(el));

      // Smooth anchors
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
          const id = a.getAttribute('href')!;
          if (id.length > 1) {
            const el = document.querySelector(id);
            if (el) { e.preventDefault(); window.scrollTo({ top: (el as HTMLElement).offsetTop - 72, behavior: 'smooth' }); }
          }
        });
      });
    </script>
  </body>
</html>
